<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="400"
    android:exitFadeDuration="400">

    <item android:state_activated="true">
        <layer-list>
            <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="150dp" android:centerX="0.5" android:centerY="0.5" android:startColor="#DDBB00FF" android:centerColor="#882200FF" android:endColor="#00000000" />
                </shape>
            </item>

            <item android:top="65dp" android:bottom="50dp" android:left="55dp" android:right="55dp">
                <shape android:shape="oval">
                    <solid android:color="#88000000" />
                </shape>
            </item>

            <item android:top="52dp" android:bottom="60dp" android:left="53dp" android:right="53dp">
                <shape android:shape="oval">
                    <gradient android:angle="90" android:startColor="#050616" android:endColor="#4A52A0" />
                </shape>
            </item>

            <item android:top="58dp" android:bottom="66dp" android:left="59dp" android:right="59dp">
                <shape android:shape="oval">
                    <gradient android:angle="135" android:startColor="#00FFFF" android:centerColor="#0066FF" android:endColor="#5500FF" />
                </shape>
            </item>
            <item android:top="58dp" android:bottom="66dp" android:left="59dp" android:right="59dp">
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="120dp" android:centerX="0.3" android:centerY="0.2" android:startColor="#BBFFFFFF" android:endColor="#00FFFFFF" />
                </shape>
            </item>

            <item android:top="84dp" android:bottom="92dp" android:left="88dp" android:right="88dp">
                <shape android:shape="oval">
                    <gradient android:angle="315" android:startColor="#55000000" android:centerColor="#11000000" android:endColor="#33FFFFFF" />
                </shape>
            </item>

            <item android:top="98dp" android:bottom="106dp" android:left="102dp" android:right="102dp">
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#44000000" android:endColor="#00000000" />
                </shape>
            </item>
            <item android:top="98dp" android:bottom="106dp" android:left="102dp" android:right="102dp">
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="50dp" android:startColor="#8800FFFF" android:endColor="#00000000" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:top="65dp" android:bottom="50dp" android:left="55dp" android:right="55dp">
                <shape android:shape="oval">
                    <solid android:color="#66000000" />
                </shape>
            </item>

            <item android:top="52dp" android:bottom="60dp" android:left="53dp" android:right="53dp">
                <shape android:shape="oval">
                    <gradient android:angle="90" android:startColor="@color/btn_connect_rim_start" android:endColor="@color/btn_connect_rim_end" />
                </shape>
            </item>

            <item android:top="58dp" android:bottom="66dp" android:left="59dp" android:right="59dp">
                <shape android:shape="oval">
                    <gradient android:angle="135" android:startColor="@color/btn_connect_body_start" android:centerColor="@color/btn_connect_body_center" android:endColor="@color/btn_connect_body_end" />
                </shape>
            </item>
            <item android:top="58dp" android:bottom="66dp" android:left="59dp" android:right="59dp">
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="120dp" android:centerX="0.3" android:centerY="0.2" android:startColor="#44FFFFFF" android:endColor="#00FFFFFF" />
                </shape>
            </item>

            <item android:top="84dp" android:bottom="92dp" android:left="88dp" android:right="88dp">
                <shape android:shape="oval">
                    <gradient android:angle="315" android:startColor="#55000000" android:centerColor="#11000000" android:endColor="#22FFFFFF" />
                </shape>
            </item>

            <item android:top="98dp" android:bottom="106dp" android:left="102dp" android:right="102dp">
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#44000000" android:endColor="#00000000" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
