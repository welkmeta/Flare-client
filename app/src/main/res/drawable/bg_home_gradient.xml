<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/gradient_base" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="@color/gradient_blue_start"
                android:endColor="@color/gradient_blue_end"
                android:centerX="0.2"
                android:centerY="0.2" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:startColor="@color/gradient_purple_start"
                android:endColor="@color/gradient_purple_end"
                android:centerX="0.8"
                android:centerY="0.8" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="350dp"
                android:startColor="@color/gradient_magenta_start"
                android:endColor="@color/gradient_magenta_end"
                android:centerX="0.9"
                android:centerY="0.1" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="@color/gradient_cyan_start"
                android:endColor="@color/gradient_cyan_end"
                android:centerX="0.1"
                android:centerY="0.9" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:startColor="@color/gradient_white_start"
                android:endColor="@color/gradient_white_end"
                android:centerX="0.5"
                android:centerY="0.4" />
        </shape>
    </item>
</layer-list>
