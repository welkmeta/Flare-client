<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_settings_subscriptions_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone"
    android:fillViewport="true"
    android:paddingBottom="160dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Toolbar Back -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btn_subscriptions_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_subscriptions_title"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/geologica_medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Auto-update Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_auto_update"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_auto_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Toggle Auto-update -->
            <LinearLayout
                android:id="@+id/btn_toggle_auto_update"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_auto_update"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_auto_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent" />
            </LinearLayout>

            <!-- Sub-item for Interval -->
            <LinearLayout
                android:id="@+id/layout_auto_update_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_update_every"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular" />

                    <EditText
                        android:id="@+id/et_update_interval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="40dp"
                        android:background="@null"
                        android:gravity="end"
                        android:hint="@string/settings_hint_update_interval"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
                        android:inputType="number"
                        android:imeOptions="actionDone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="с"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
                        android:layout_marginStart="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
