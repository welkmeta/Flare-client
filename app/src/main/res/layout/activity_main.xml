<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blur_target"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/root_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_home"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_vertical_center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_top_40"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.38" />

                <View
                    android:id="@+id/v_glow"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:background="@drawable/bg_blue_glow"
                    android:alpha="0"
                    app:layout_constraintStart_toStartOf="@+id/btn_connect_container"
                    app:layout_constraintEnd_toEndOf="@+id/btn_connect_container"
                    app:layout_constraintTop_toTopOf="@+id/btn_connect_container"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_connect_container" />

                <FrameLayout
                    android:id="@+id/btn_connect_container"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_marginBottom="-50dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/guideline_top_40">

                    <View
                        android:id="@+id/btn_connect"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_connect_button_v3"
                        android:stateListAnimator="@null" />

                    <ImageView
                        android:id="@+id/iv_connect_icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:translationY="-2dp"
                        android:src="@drawable/ic_power"
                        app:tint="@color/btn_connect_icon_tint" />

                    <ImageView
                        android:id="@+id/iv_stop_icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:translationY="-2dp"
                        android:src="@drawable/ic_power"
                        android:visibility="gone"
                        app:tint="@color/white" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="00:00:00"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geologica_medium"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/guideline_top_40"
                    app:layout_constraintStart_toStartOf="@id/btn_connect_container"
                    app:layout_constraintEnd_toEndOf="@id/btn_connect_container" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_profiles"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:clipToPadding="false"
                    android:paddingBottom="8dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/tv_timer"
                    app:layout_constraintBottom_toTopOf="@id/layout_bottom_actions"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:id="@+id/layout_bottom_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="116dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tv_add_profiles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Добавить профили"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_add_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:layout_marginHorizontal="32dp"
                        android:gravity="center"
                        android:text="@string/hint_add_first_profile"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/geologica_regular"
                        android:visibility="gone" />

                    <FrameLayout
                        android:id="@+id/btn_clipboard"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_clipboard_button"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tv_clipboard_text"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingStart="28dp"
                            android:paddingEnd="28dp"
                            android:text="Буфер обмена"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:fontFamily="@font/geologica_medium" />

                        <ProgressBar
                            android:id="@+id/pb_clipboard_loading"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/white"
                            android:visibility="gone" />
                    </FrameLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <include
                android:id="@+id/layout_settings"
                layout="@layout/layout_settings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_settings_advanced_container"
                layout="@layout/layout_settings_advanced"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_settings_ping_container"
                layout="@layout/layout_settings_ping"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_settings_base_container"
                layout="@layout/layout_settings_base"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_settings_subscriptions_container"
                layout="@layout/layout_settings_subscriptions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_settings_theme_container"
                layout="@layout/layout_settings_theme"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_custom_servers_container"
                layout="@layout/layout_servers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <include
                android:id="@+id/layout_onboarding"
                layout="@layout/layout_onboarding"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_json_editor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_dark"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/toolbar_json"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/btn_json_back"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@drawable/ic_arrow_left"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/text_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_json_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Редактор конфига"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/geologica_medium"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintStart_toEndOf="@id/btn_json_back"
                        app:layout_constraintEnd_toStartOf="@id/btn_json_save"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/btn_json_save"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@drawable/ic_check"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/accent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:fillViewport="true"
                    app:layout_constraintTop_toBottomOf="@id/toolbar_json"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_profile_name"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/geologica_regular"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/et_json_profile_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_grouped_all"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:fontFamily="@font/geologica_medium"
                            android:inputType="text"
                            android:maxLines="1"
                            android:layout_marginBottom="24dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_json_data"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/geologica_regular"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/et_json_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_grouped_all"
                            android:padding="12dp"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/geologica_regular"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:minLines="10" />

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </eightbitlab.com.blurview.BlurTarget>

    <flare.client.app.ui.widget.SlidingBottomNav
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <include
        android:id="@+id/notification_include"
        layout="@layout/layout_notification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp" />

</FrameLayout>
