<?xml version="1.0" encoding="utf-8"?>
<eightbitlab.com.blurview.BlurTarget
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/blur_target"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_home"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav">

        <!-- ── Power button (slightly above center) ──────── -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_vertical_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_top_40"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.38" />

        <View
            android:id="@+id/v_glow"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/bg_blue_glow"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="@+id/btn_connect_container"
            app:layout_constraintEnd_toEndOf="@+id/btn_connect_container"
            app:layout_constraintTop_toTopOf="@+id/btn_connect_container"
            app:layout_constraintBottom_toBottomOf="@+id/btn_connect_container" />

        <FrameLayout
            android:id="@+id/btn_connect_container"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_marginBottom="-50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_top_40">

            <View
                android:id="@+id/btn_connect"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_connect_button_v3"
                android:stateListAnimator="@null" />

            <!-- Default state: Power Icon (Dimmed / Off) -->
            <ImageView
                android:id="@+id/iv_connect_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:translationY="-2dp"
                android:src="@drawable/ic_power"
                app:tint="#A0A5D6" />



            <!-- Active state: Power Icon (Glowing / On) -->
            <ImageView
                android:id="@+id/iv_stop_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:translationY="-2dp"
                android:src="@drawable/ic_power"
                android:visibility="gone"
                app:tint="@color/white" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="00:00:00"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/geologica_medium"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/guideline_top_40"
            app:layout_constraintStart_toStartOf="@id/btn_connect_container"
            app:layout_constraintEnd_toEndOf="@id/btn_connect_container" />

        <!-- ── Profile list (below timer) ────────────────────── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_profiles"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_timer"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_actions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Bottom area ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_bottom_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_add_profiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Добавить профили"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/geologica_regular" />

            <Button
                android:id="@+id/btn_clipboard"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:text="Буфер обмена"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="@font/geologica_medium"
                android:backgroundTint="@null"
                android:background="@drawable/bg_clipboard_button"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/layout_settings"
        layout="@layout/layout_settings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layout_settings_advanced_container"
        layout="@layout/layout_settings_advanced"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layout_settings_ping_container"
        layout="@layout/layout_settings_ping"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layout_settings_base_container"
        layout="@layout/layout_settings_base"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layout_settings_subscriptions_container"
        layout="@layout/layout_settings_subscriptions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layout_settings_theme_container"
        layout="@layout/layout_settings_theme"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tv_servers_placeholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Скоро тут появится возможность создавать свой прокси сервер"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="@font/geologica_medium"
        android:visibility="gone"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav" />

    <flare.client.app.ui.widget.SlidingBottomNav
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ── JSON Editor Layout ────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_json_editor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbar_json"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_json_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_json_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Редактор конфига"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="@font/geologica_medium"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@id/btn_json_back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/btn_json_copy"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_check"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/accent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/toolbar_json"
            app:layout_constraintBottom_toBottomOf="parent">

            <EditText
                android:id="@+id/et_json_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@null"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:hint="JSON config here..."
                android:textColorHint="@color/text_secondary" />

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:id="@+id/notification_include"
        layout="@layout/layout_notification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

</eightbitlab.com.blurview.BlurTarget>
