<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_settings_ping"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone"
    android:fillViewport="true"
    android:paddingBottom="160dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btn_ping_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_ping_title"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/geologica_medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_ping_type"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:layout_marginBottom="4dp">

            <FrameLayout
                android:id="@+id/btn_ping_type_get"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_grouped_all"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_ping_type_get"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/settings_ping_type_get"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_regular"
                    android:gravity="center"
                    android:padding="8dp" />

                <ImageView
                    android:id="@+id/iv_ping_type_get_check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/accent"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_ping_type_head"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_grouped_all"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_ping_type_head"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/settings_ping_type_head"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_regular"
                    android:gravity="center"
                    android:padding="8dp" />

                <ImageView
                    android:id="@+id/iv_ping_type_head_check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/accent"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_ping_type_tcp"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_grouped_all"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_ping_type_tcp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/settings_ping_type_tcp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_regular"
                    android:gravity="center"
                    android:padding="8dp" />

                <ImageView
                    android:id="@+id/iv_ping_type_tcp_check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/accent"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_ping_type_icmp"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_grouped_all"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_ping_type_icmp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/settings_ping_type_icmp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/geologica_regular"
                    android:gravity="center"
                    android:padding="8dp" />

                <ImageView
                    android:id="@+id/iv_ping_type_icmp_check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/accent"
                    android:visibility="gone" />
            </FrameLayout>

        </GridLayout>

        <TextView
            android:id="@+id/tv_ping_type_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_test_url"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_grouped_all"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_test_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/settings_hint_test_url"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_desc_test_url"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_ping_display"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/btn_ping_style"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_grouped_all"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_label_ping_style"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_regular" />

            <TextView
                android:id="@+id/tv_ping_style_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_ping_style_time"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
