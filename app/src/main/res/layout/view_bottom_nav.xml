<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Container for the glass bar -->
    <FrameLayout
        android:id="@+id/nav_container_frame"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp">

        <!--
            BlurView — настоящее frosted glass.
            Захватывает снимок BlurTarget и размывает на GPU.
            background=bg_bottom_nav: rounded shape + subtle tint + border.
            blurOverlayColor убран — тонировка уже в bg_bottom_nav.
        -->
        <eightbitlab.com.blurview.BlurView
            android:id="@+id/glass_blur_view"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav" />

        <!-- Liquid Pill Indicator -->
        <flare.client.app.ui.widget.LiquidPillView
            android:id="@+id/nav_liquid_indicator"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom" />

        <!-- Navigation Icons -->
        <LinearLayout
            android:id="@+id/nav_icons_row"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_nav_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_settings"
                android:tint="@android:color/white"
                android:alpha="0.5" />

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@android:color/white"
                android:alpha="1.0" />

            <ImageView
                android:id="@+id/iv_nav_servers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_servers"
                android:tint="@android:color/white"
                android:alpha="0.5" />
        </LinearLayout>
    </FrameLayout>
</merge>
