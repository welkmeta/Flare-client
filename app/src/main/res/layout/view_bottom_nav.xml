<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout structure:
    - SlidingBottomNav (FrameLayout, clipChildren=false → allows indicator to overflow)
      └── nav_container (BlurView, just a transparent holder, NO RenderEffect)
            ├── nav_blur_bg (View) ← ONLY this view gets RenderEffect blur + rounded bg
            ├── nav_indicator_glow (GlowView, overflows above)
            ├── nav_indicator (the sliding pill)
            └── LinearLayout (icons row)
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Outer FrameLayout acts only as a size anchor, no background, no clipping -->
    <FrameLayout
        android:id="@+id/nav_container_frame"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginHorizontal="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Glass blur background — ONLY this gets the RenderEffect.
             It sits at the bottom of the Z-order, sized to the pill area (64dp + 16dp margins from top). -->
        <View
            android:id="@+id/nav_blur_bg"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav" />

        <!-- GlowView: overflows upward, so it must be in the non-clipped parent -->
        <flare.client.app.ui.widget.GlowView
            android:id="@+id/nav_indicator_glow"
            android:layout_width="10px"
            android:layout_height="10px"
            android:layout_gravity="bottom"
            android:alpha="0" />

        <!-- Sliding indicator pill — can overflow the nav_blur_bg bounds -->
        <View
            android:id="@+id/nav_indicator"
            android:layout_width="100dp"
            android:layout_height="58dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="3dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/bg_nav_indicator" />

        <!-- Icons row, sits above the blur bg -->
        <LinearLayout
            android:id="@+id/nav_icons_row"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_nav_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_settings"
                android:tint="@color/nav_icon_tint" />

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/nav_icon_tint" />

            <ImageView
                android:id="@+id/iv_nav_servers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="20dp"
                android:src="@drawable/ic_nav_servers"
                android:tint="@color/nav_icon_tint" />
        </LinearLayout>
    </FrameLayout>
</merge>
