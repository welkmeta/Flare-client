<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notification_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginTop="32dp"
    android:translationY="-150dp"
    android:background="@drawable/bg_notification"
    android:elevation="8dp">

    <ImageView
        android:id="@+id/iv_notification_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginVertical="24dp"
        android:src="@drawable/ic_success"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tv_notification_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginVertical="24dp"
        android:fontFamily="@font/geologica_medium"
        android:text="Notification text"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/iv_notification_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Progress bar at the bottom -->
    <!-- Placing it at the bottom, matching constraints, but needing rounded corners.
         Actually, a simple View is fine, but to fit nicely at bottom edge containing rounds,
         it might overlap corners if it's full width. Alternatively we can give it horizontal margin or use a specific Shape.
         Using horizontal margin to keep it inside the rounded border. -->
    <View
        android:id="@+id/v_notification_progress"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@color/accent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
