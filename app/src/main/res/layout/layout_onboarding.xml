<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_step_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp">

        <TextView
            android:id="@+id/tv_welcome_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_welcome_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/geologica_medium"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tv_welcome_question"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tv_welcome_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/onboarding_welcome_question"
            android:textColor="@color/text_secondary"
            android:textSize="17sp"
            android:fontFamily="@font/geologica_regular"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_title"
            app:layout_constraintBottom_toTopOf="@+id/ll_welcome_options"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/ll_welcome_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome_question"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btn_welcome_yes"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_button_accent"
                android:gravity="center"
                android:text="@string/option_yes"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/btn_welcome_no"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_server_card"
                android:gravity="center"
                android:text="@string/option_no"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_step_permissions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_permissions_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/onboarding_permissions_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/geologica_medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/btn_permission_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:background="@drawable/bg_server_card"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_permissions_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/iv_notif_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_notifications"
                    app:tint="@color/accent" />

                <TextView
                    android:id="@+id/tv_notif_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/onboarding_notifications_title"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geologica_medium" />

                <ImageView
                    android:id="@+id/iv_notif_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/white"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_notif_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_notifications_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/geologica_regular"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_permission_battery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_server_card"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btn_permission_notifications">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/iv_battery_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_battery"
                    app:tint="@color/accent" />

                <TextView
                    android:id="@+id/tv_battery_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/onboarding_battery_title"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geologica_medium" />

                <ImageView
                    android:id="@+id/iv_battery_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/white"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_battery_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_battery_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/geologica_regular"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_step_fragmentation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0"
        android:padding="32dp">

        <TextView
            android:id="@+id/tv_frag_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/onboarding_fragmentation_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/geologica_medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_frag_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_fragmentation_question"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/geologica_medium"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/ll_frag_options"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <LinearLayout
            android:id="@+id/ll_frag_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_frag_question"
            app:layout_constraintBottom_toTopOf="@+id/tv_frag_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btn_frag_yes"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_button_accent"
                android:gravity="center"
                android:text="@string/option_yes"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/btn_frag_no"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_server_card"
                android:gravity="center"
                android:text="@string/option_no"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_frag_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/onboarding_fragmentation_desc"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="@font/geologica_regular"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            app:layout_constraintTop_toBottomOf="@id/ll_frag_options"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_step_mux"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0"
        android:padding="32dp">

        <TextView
            android:id="@+id/tv_mux_title_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/onboarding_mux_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/geologica_medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_mux_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_mux_question"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/geologica_medium"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/ll_mux_options"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <LinearLayout
            android:id="@+id/ll_mux_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_mux_question"
            app:layout_constraintBottom_toTopOf="@+id/tv_mux_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btn_mux_yes"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_button_accent"
                android:gravity="center"
                android:text="@string/option_yes"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/btn_mux_no"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_server_card"
                android:gravity="center"
                android:text="@string/option_no"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_mux_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/onboarding_mux_desc"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="@font/geologica_regular"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            app:layout_constraintTop_toBottomOf="@id/ll_mux_options"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_step_success"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0"
        android:padding="32dp">

        <ImageView
            android:id="@+id/iv_success_check"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check"
            app:tint="@color/connected_green"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tv_success_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tv_success_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/onboarding_success_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="@font/geologica_medium"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/iv_success_check"
            app:layout_constraintBottom_toTopOf="@+id/btn_onboarding_finish"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/btn_onboarding_finish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_server_card"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_success_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/onboarding_btn_go_main"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/geologica_medium" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
