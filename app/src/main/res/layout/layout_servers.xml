<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_custom_servers"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_servers_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сервера"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="24dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layout_server_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/btn_flare_servers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_server_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:id="@+id/iv_flare_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_cloud"
                            app:tint="@color/accent" />

                        <TextView
                            android:id="@+id/tv_flare_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="@string/servers_title_flare"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:fontFamily="@font/geologica_medium" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_flare_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_desc_flare"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_create_server"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_server_card"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:id="@+id/iv_create_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_suitcase"
                            app:tint="@color/accent" />

                        <TextView
                            android:id="@+id/tv_create_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="@string/servers_title_create"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:fontFamily="@font/geologica_medium" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_create_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_desc_create"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geologica_regular"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_ssh_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:alpha="0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_ssh_profile_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/et_ssh_profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grouped_all"
                        android:padding="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:hint="@string/servers_ssh_profile_name_hint"
                        android:fontFamily="@font/geologica_medium"
                        android:maxLines="1"
                        android:inputType="textPersonName" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/servers_ssh_ip"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/geologica_regular"
                            android:layout_marginBottom="8dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <EditText
                                android:id="@+id/et_ssh_ip"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_grouped_all"
                                android:padding="14sp"
                                android:paddingEnd="42dp"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_secondary"
                                android:textSize="15sp"
                                android:hint="0.0.0.0"
                                android:fontFamily="@font/geologica_medium"
                                android:maxLines="1"
                                android:inputType="text" />

                            <ImageView
                                android:id="@+id/iv_check_ip"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_gravity="end|center_vertical"
                                android:padding="10dp"
                                android:src="@drawable/ic_check"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/servers_ssh_port"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="@font/geologica_regular"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/et_ssh_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_grouped_all"
                            android:padding="14sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:hint="@string/servers_ssh_port_hint"
                            android:fontFamily="@font/geologica_medium"
                            android:maxLines="1"
                            android:inputType="number" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_ssh_username"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/et_ssh_user"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grouped_all"
                        android:padding="14sp"
                        android:paddingEnd="48dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:hint="root"
                        android:fontFamily="@font/geologica_medium"
                        android:maxLines="1"
                        android:inputType="text" />

                    <ImageView
                        android:id="@+id/iv_check_user"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:padding="10dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_ssh_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/et_ssh_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grouped_all"
                        android:padding="14sp"
                        android:paddingEnd="84dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:fontFamily="@font/geologica_medium"
                        android:inputType="textPassword"
                        android:maxLines="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_check_password"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:padding="10dp"
                            android:src="@drawable/ic_check"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/btn_ssh_key"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:padding="14dp"
                            android:src="@drawable/ic_vpn_key"
                            app:tint="@color/text_secondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_protocol_selection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:alpha="0">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_protocol_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/geologica_regular"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/btn_protocol_xray"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_server_card_selected"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_security"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="@string/servers_protocol_xray_title"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="@font/geologica_medium" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_protocol_xray_desc"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:alpha="0.8"
                        android:fontFamily="@font/geologica_regular"
                        android:lineSpacingExtra="1dp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/layout_xray_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:alpha="0"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_xray_setup_title"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/geologica_medium"
                    android:layout_marginBottom="32dp"
                    android:layout_marginTop="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_xray_port_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/geologica_regular"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_xray_port"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grouped_all"
                        android:padding="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:hint="443"
                        android:fontFamily="@font/geologica_medium"
                        android:maxLines="1"
                        android:inputType="number"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_xray_port_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:fontFamily="@font/geologica_regular"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_xray_sni_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/geologica_regular"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_xray_sni"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_grouped_all"
                        android:padding="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:hint="google.com"
                        android:fontFamily="@font/geologica_medium"
                        android:maxLines="1"
                        android:inputType="text"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/servers_xray_sni_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:fontFamily="@font/geologica_regular"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_setup_progress_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:alpha="0"
                android:gravity="center_horizontal"
                android:paddingTop="32dp">

                <TextSwitcher
                    android:id="@+id/tv_setup_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:inAnimation="@anim/slide_in_top"
                    android:outAnimation="@anim/slide_out_bottom" />

                <ProgressBar
                    android:id="@+id/pb_setup_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:max="100"
                    android:progressDrawable="@drawable/bg_progress_bar"
                    android:layout_marginBottom="16dp" />

                <flare.client.app.ui.widget.AnimatedPercentView
                    android:id="@+id/tv_setup_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_setup_success_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:alpha="0"
                android:gravity="center_horizontal"
                android:paddingTop="32dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/connected_green"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_setup_success"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/geologica_medium"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servers_setup_success_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="@font/geologica_regular"
                    android:gravity="center" />

                <LinearLayout
                    android:id="@+id/btn_go_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_server_card"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginTop="32dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_left"
                        app:tint="@color/accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="На главную"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/geologica_medium" />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
