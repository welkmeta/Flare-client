<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_settings_advanced"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:visibility="gone"
    android:fillViewport="true"
    android:paddingBottom="160dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btn_advanced_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_advanced_title"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_fragmentation"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_fragmentation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/btn_toggle_fragmentation"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_fragmentation"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_fragmentation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_fragmentation_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_packet_type"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_middle"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_packet_type"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_packet_type_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="tlshello"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_fragment_interval"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_fragment_interval"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <EditText
                        android:id="@+id/et_fragment_interval"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="end"
                        android:hint="10"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                        android:inputType="number"
                        android:imeOptions="actionDone" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fragment_desc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_mux"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_mux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/btn_toggle_mux"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_mux"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_mux"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_mux_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/divider_color" />

                <LinearLayout
                    android:id="@+id/btn_mux_protocol"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_middle"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_mux_protocol"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_mux_protocol_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="smux"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_middle"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_mux_streams"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <EditText
                        android:id="@+id/et_mux_max_streams"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="end"
                        android:hint="8"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                        android:inputType="number"
                        android:imeOptions="actionDone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_mux_padding"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_grouped_bottom"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_label_mux_padding"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                    <TextView
                        android:id="@+id/tv_mux_padding_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/option_no"
                        android:textColor="@color/accent"
                        android:tag="accent_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mux_desc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_remote_dns"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_remote_dns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_dns_url"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <EditText
                    android:id="@+id/et_remote_dns_url"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="end"
                    android:hint="@string/settings_hint_dns_url"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/accent"
                    android:tag="accent_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                    android:inputType="textUri"
                    android:imeOptions="actionDone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_fake_ip"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_fake_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/btn_toggle_fake_ip"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_use_fake_ip"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_fake_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fakeip_desc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_mtu_title"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_mtu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_mtu"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <EditText
                    android:id="@+id/et_mtu"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="end"
                    android:hint="1500"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/accent"
                    android:tag="accent_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
                    android:inputType="number"
                    android:imeOptions="actionDone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mtu_desc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_stack_header"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <LinearLayout
            android:id="@+id/block_stack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/btn_stack_type"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_grouped_all"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_stack_title"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular" />

                <TextView
                    android:id="@+id/tv_stack_type_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_label_stack"
                    android:textColor="@color/accent"
                    android:tag="accent_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/geologica_medium"
            app:fontFamily="@font/geologica_medium" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_stack_type_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/geologica_regular"
            app:fontFamily="@font/geologica_regular"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
